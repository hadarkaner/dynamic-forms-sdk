generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  EMAIL
  PHONE
  DATE
  RATING
  CHECKBOX
  RADIO
  SELECT
}

enum EventType {
  VIEW
  START
  FIELD_FOCUS
  FIELD_CHANGE
  SUBMIT
  ABANDON
  ERROR
}

model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  forms     Form[]
  formSlots FormSlot[]

  @@map("api_keys")
}

// A Form is a stable container — it owns versions, submissions, and analytics events,
// but holds no editable content itself. All content lives on FormVersion.
model Form {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeyId String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  versions        FormVersion[]
  submissions     FormSubmission[]
  analyticsEvents AnalyticsEvent[]
  formSlots       FormSlot[]

  @@index([apiKeyId])
  @@map("forms")
}

// A named, stable pointer to a Form — lets an embedding app hold a fixed slot key
// (e.g. "main-survey") while the admin swaps which published form answers it,
// entirely from the portal, with no app-side change or release. `key` is globally
// unique (not just per-ApiKey): the public resolution endpoint has no api-key
// context to disambiguate by, the same tradeoff `Form.id` already makes as a public
// identifier. `formId` is nullable — a slot can exist unassigned.
model FormSlot {
  id        String   @id @default(uuid())
  key       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeyId String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  formId String?
  form   Form?   @relation(fields: [formId], references: [id], onDelete: SetNull)

  @@index([apiKeyId])
  @@map("form_slots")
}

// Versions are immutable once created. "Current" = highest versionNumber for the form.
// "Published" = the version with isPublished = true (at most one per form, enforced in
// the service layer inside a transaction when publishing).
model FormVersion {
  id            String    @id @default(uuid())
  versionNumber Int
  title         String
  description   String?
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  // Per-form visual styling (colors, font) applied by the client SDK when rendering.
  theme         Json?

  formId String
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)

  fields FormField[]

  @@unique([formId, versionNumber])
  @@index([formId])
  @@map("form_versions")
}

model FormField {
  id          String    @id @default(uuid())
  label       String
  type        FieldType
  isRequired  Boolean   @default(false)
  order       Int       @default(0)
  options     Json?
  // Subset of `options` marked correct by the form editor; only meaningful for
  // RADIO/CHECKBOX fields. Authoring-time metadata only — never used to grade
  // submissions automatically.
  correctOptions Json?
  placeholder String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  formVersionId String
  formVersion   FormVersion @relation(fields: [formVersionId], references: [id], onDelete: Cascade)

  @@index([formVersionId])
  @@map("form_fields")
}

model FormSubmission {
  id          String   @id @default(uuid())
  data        Json
  submittedAt DateTime @default(now())
  ipAddress   String?
  userAgent   String?

  formId String
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@map("form_submissions")
}

model AnalyticsEvent {
  id        String    @id @default(uuid())
  type      EventType
  metadata  Json?
  createdAt DateTime  @default(now())

  formId String
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([type])
  @@map("analytics_events")
}
